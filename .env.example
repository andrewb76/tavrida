# =============================================================================
# Tavrida Lot — Platform environment variables
# =============================================================================
# Copy:  cp .env.example .env.local
# Docs:  docs/02-infrastructure/PLATFORM-SECRETS.md
# NEVER commit .env.local or real secrets to git.
# =============================================================================

# --- Runtime ---
NODE_ENV=development

# --- PostgreSQL (shared instance, schema per service — ADR-001) ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/tavrida_lot

# Scaffold alternative (used in services/*/ormconfig.ts when DATABASE_URL unset)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=tavrida_lot

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- RabbitMQ ---
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# --- MinIO (S3-compatible) ---
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_URL=http://localhost:9000
MEDIA_PUBLIC_BASE_URL=http://localhost:9000

# --- Image proxy (imgproxy) ---
# Browser loads resized images from imgproxy; imgproxy fetches originals from MinIO.
IMAGE_PROXY_URL=http://localhost:8080
IMAGE_PROXY_FETCH_BASE_URL=http://minio:9000
VITE_IMAGE_PROXY_URL=http://localhost:8080
VITE_IMAGE_PROXY_FETCH_BASE_URL=http://minio:9000
VITE_MEDIA_PUBLIC_BASE_URL=http://localhost:9000

# --- Logto (OIDC / JWT) ---
LOGTO_ENDPOINT=https://logto.example.com
LOGTO_JWKS_URL=https://logto.example.com/oidc/jwks
LOGTO_AUDIENCE=https://api.tavrida-lot.localhost
# M2M — BFF Management API (invites / one-time tokens)
# Cloud: https://<tenant>.logto.app/api  |  OSS: https://default.logto.app/api
# If unset or OSS default on Cloud tenant, BFF derives {LOGTO_ENDPOINT}/api automatically.
LOGTO_M2M_APP_ID=
LOGTO_M2M_APP_SECRET=
LOGTO_M2M_RESOURCE=https://default.logto.app/api
# Webhook signing key from Logto Console → Webhooks (or pnpm setup:logto-webhook)
LOGTO_WEBHOOK_SIGNING_KEY=
# Public URL for Logto to POST webhooks (local: ngrok/cloudflared tunnel to BFF)
# LOGTO_WEBHOOK_ENDPOINT_URL=https://<tunnel>/api/v1/webhooks/logto
FRONTEND_ORIGIN=http://localhost:5173

# --- Ory Keto (RBAC) ---
KETO_READ_URL=http://localhost:4466
KETO_WRITE_URL=http://localhost:4467
# Keto storage (docker only — schema keto in tavrida_lot):
# postgres://postgres:postgres@postgres:5432/tavrida_lot?sslmode=disable&search_path=keto
# KETO_NAMESPACE=TavridaLot
# KETO_PLATFORM_OBJECT=platform:tavrida-lot
# KETO_ADMIN_RELATION=admin

# --- Novu (notifications adapter) ---
NOVU_API_KEY=
NOVU_API_URL=https://api.novu.co
NOVU_APPLICATION_IDENTIFIER=

# --- Observability ---
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# =============================================================================
# BFF (port 3000)
# =============================================================================
BFF_PORT=3000
# Do not set global PORT in .env.local — turbo shares env across services.
# Each service prefers its own *_PORT (see local-dev.md). Dev scripts also pin ports.
# USER_PROFILE_PORT=3007
# SCALAR_CONFIG_PORT=3008
CORS_ORIGINS=https://app.tavrida-lot.localhost,http://localhost:5173

BILLING_URL=http://localhost:3001
PLAN_CONFIG_URL=http://localhost:3002
AUCTION_URL=http://localhost:3003
SUBSCRIPTIONS_URL=http://localhost:3004
# AUCTION_SUBSCRIPTIONS_URL=http://localhost:3004
RATING_URL=http://localhost:3005
FEEDBACK_URL=http://localhost:3006
DEAL_FEEDBACK_URL=http://localhost:3006
USER_PROFILE_URL=http://localhost:3007
SCALAR_CONFIG_URL=http://localhost:3008
FORUM_URL=http://localhost:3009
NOTIFICATIONS_URL=http://localhost:3010
MARKETPLACE_URL=http://localhost:3011
PERIODS_URL=http://localhost:3014

# Invite limits (v1 env fallback until plan-config integration)
# CLUB_INVITE_VALIDITY_DAYS — fallback only; primary: scalar-config club.invite.validityDays (admin UI)
CLUB_INVITE_VALIDITY_DAYS=14
CLUB_INVITES_PER_MONTH=10
# Comma-separated Logto user IDs with unlimited invites (bootstrap admin)
CLUB_INVITES_UNLIMITED_ISSUER_IDS=

# =============================================================================
# Microservices — PORT overrides (defaults baked into each service)
# Priority: <SERVICE>_PORT → PORT (deploy) → default in main.ts
# =============================================================================
# BILLING_PORT=3001
# PLAN_CONFIG_PORT=3002
# AUCTION_PORT=3003
# SUBSCRIPTIONS_PORT=3004
# USER_PROFILE_PORT=3007
# SCALAR_CONFIG_PORT=3008
# FORUM_PORT=3009
# PERIODS_PORT=3014
# MARKETPLACE_PORT=3011

# Per-service Sentry (optional, falls back to SENTRY_DSN)
# OTEL_SERVICE_NAME=billing

# =============================================================================
# Frontend (VITE_* — exposed to browser, no secrets)
# Loaded by apps/frontend via vite envDir = repo root
# =============================================================================
VITE_USE_MOCK=true
VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_WS_URL=ws://localhost:3000/ws/v1

# Logto Cloud (SaaS) — https://cloud.logto.io
# Create SPA app, then set redirect URIs:
#   Sign-in:  http://localhost:5173/callback
#   Sign-out: http://localhost:5173/
#   CORS:     http://localhost:5173
# Full guide: docs/14-frontend/logto-setup.md
# VITE_LOGTO_ENDPOINT=https://<tenant>.logto.app
# VITE_LOGTO_APP_ID=<app-id>
# API resource (JWT audience for BFF — required when VITE_USE_MOCK=false):
VITE_LOGTO_API_RESOURCE=https://api.tavrida-lot.localhost

VITE_NOVU_APPLICATION_IDENTIFIER=
VITE_SENTRY_DSN=
