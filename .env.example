# =============================================================================
# Tavrida Lot — Platform environment variables
# =============================================================================
# Copy:  cp .env.example .env.local
# Docs:  docs/02-infrastructure/PLATFORM-SECRETS.md
# NEVER commit .env.local or real secrets to git.
# =============================================================================

# --- Runtime ---
NODE_ENV=development

# --- PostgreSQL (shared instance, schema per service — ADR-001) ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/tavrida_lot

# Scaffold alternative (used in services/*/ormconfig.ts when DATABASE_URL unset)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=tavrida_lot

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- RabbitMQ ---
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# --- MinIO (S3-compatible) ---
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_URL=http://localhost:9000

# --- Logto (OIDC / JWT) ---
LOGTO_ENDPOINT=https://logto.example.com
LOGTO_JWKS_URL=https://logto.example.com/oidc/jwks
LOGTO_AUDIENCE=https://api.tavrida-lot.localhost

# --- Ory Keto (RBAC) ---
KETO_READ_URL=http://localhost:4466
KETO_WRITE_URL=http://localhost:4467

# --- Novu (notifications adapter) ---
NOVU_API_KEY=
NOVU_API_URL=https://api.novu.co
NOVU_APPLICATION_IDENTIFIER=

# --- Observability ---
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# =============================================================================
# BFF (port 3000)
# =============================================================================
BFF_PORT=3000
PORT=3000
CORS_ORIGINS=https://app.tavrida-lot.localhost,http://localhost:5173

BILLING_URL=http://localhost:3001
FINANCIAL_POLICY_URL=http://localhost:3002
AUCTION_URL=http://localhost:3003
AUCTION_SUBSCRIPTIONS_URL=http://localhost:3004
RATING_URL=http://localhost:3005
FEEDBACK_URL=http://localhost:3006
USER_PROFILE_URL=http://localhost:3007
SETTINGS_URL=http://localhost:3008
FORUM_URL=http://localhost:3009
NOTIFICATIONS_URL=http://localhost:3010
MARKETPLACE_URL=http://localhost:3011

# =============================================================================
# Microservices — PORT overrides (defaults baked into each service)
# =============================================================================
# BILLING_PORT=3001
# FINANCIAL_POLICY_PORT=3002
# AUCTION_PORT=3003
# AUCTION_SUBSCRIPTIONS_PORT=3004

# Per-service Sentry (optional, falls back to SENTRY_DSN)
# OTEL_SERVICE_NAME=billing

# =============================================================================
# Frontend (VITE_* — exposed to browser, no secrets)
# =============================================================================
VITE_API_URL=http://localhost:3000/api/v1
VITE_WS_URL=ws://localhost:3000/ws/v1
VITE_LOGTO_ENDPOINT=https://logto.example.com
VITE_LOGTO_APP_ID=
VITE_NOVU_APPLICATION_IDENTIFIER=
VITE_SENTRY_DSN=
