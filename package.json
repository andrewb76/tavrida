{
  "name": "tavrida-lot",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "generate": "turbo run generate",
    "docs:dev": "pnpm --filter @tavrida/docs-site dev",
    "docs:build": "pnpm --filter @tavrida/docs-site build",
    "docs:preview": "pnpm --filter @tavrida/docs-site preview",
    "audit": "pnpm audit --audit-level=high"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@vue/eslint-config-typescript": "^14.5.0",
    "eslint": "^9.18.0",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^15.14.0",
    "prettier": "^3.5.0",
    "turbo": "^2.3.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "lodash": ">=4.18.1",
      "multer": ">=2.2.0",
      "qs": ">=6.15.2",
      "vite": ">=6.4.3"
    }
  }
}
