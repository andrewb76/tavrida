{
  "name": "tavrida-lot",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "eslint \"{apps,packages,services}/**/src/**/*.{ts,vue}\" --fix",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "generate": "turbo run generate",
    "setup:env": "sh scripts/setup-env.sh",
    "check:logto": "node scripts/check-logto-env.mjs",
    "setup:logto-webhook": "node scripts/setup-logto-webhook.mjs",
    "setup:logto-branding": "node scripts/setup-logto-branding.mjs",
    "sync:logto-users": "node scripts/sync-logto-users.mjs",
    "grant:admin": "sh scripts/grant-admin.sh",
    "infra:up": "docker compose -f docker/compose/infra.local.yml --env-file .env.local up -d",
    "infra:down": "docker compose -f docker/compose/infra.local.yml --env-file .env.local down",
    "novu:up": "docker compose -f docker/compose/novu.local.yml --env-file docker/compose/novu.local.env up -d",
    "novu:down": "docker compose -f docker/compose/novu.local.yml --env-file docker/compose/novu.local.env down",
    "docs:dev": "pnpm --filter @tavrida/docs-site dev",
    "docs:build": "pnpm --filter @tavrida/docs-site build",
    "docs:preview": "pnpm --filter @tavrida/docs-site preview",
    "audit": "pnpm audit --audit-level=high"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@vue/eslint-config-typescript": "^14.5.0",
    "eslint": "^9.18.0",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^15.14.0",
    "prettier": "^3.5.0",
    "turbo": "^2.3.0"
  },
  "engines": {
    "node": ">=22.13",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.13.0"
}
