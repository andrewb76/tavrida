{
  "$schema": "https://turbo.build",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"]
    },
    "lint": {},
    "test": {
      "dependsOn": ["build"]
    },
    "test:bdd": {
      "dependsOn": ["build"]
    },
    "test:load": {}
  }
}