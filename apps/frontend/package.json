{
  "name": "@tavrida/frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "pnpm exec vite",
    "build": "pnpm --filter @tavrida/object-storage run build && vue-tsc -b && pnpm exec vite build",
    "preview": "pnpm exec vite preview",
    "lint": "eslint src",
    "pretest": "tsc -p tsconfig.test.json",
    "test": "node --test dist-test/**/*.test.js",
    "check:logto": "node ../../scripts/check-logto-env.mjs"
  },
  "dependencies": {
    "@logto/vue": "^3.0.13",
    "@tanstack/vue-query": "^5.62.8",
    "@tavrida/object-storage": "workspace:*",
    "@tavrida/shared": "workspace:*",
    "@tavrida/ui": "workspace:*",
    "@vueuse/core": "^12.0.0",
    "dompurify": "^3.4.12",
    "markdown-it": "^14.3.0",
    "pinia": "^2.3.0",
    "vue": "^3.5.13",
    "vue-i18n": "^10.0.5",
    "vue-router": "^4.5.0",
    "vue-sonner": "^1.3.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.0.0",
    "@tavrida/tsconfig": "workspace:*",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.14.0",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/tsconfig": "^0.7.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.4.5",
    "vite": "^6.0.7",
    "vue-tsc": "^2.2.0"
  }
}
