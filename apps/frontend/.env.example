# Frontend env — loaded from monorepo root (vite envDir)
#
#   cp ../../.env.example ../../.env.local
#   # fill VITE_LOGTO_* in ../../.env.local
#
# Or copy only frontend vars into apps/frontend/.env.local (also works if envDir changes).
#
# Logto setup: ../../docs/14-frontend/logto-setup.md

VITE_USE_MOCK=true
VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_WS_URL=ws://localhost:3000/ws/v1

# VITE_LOGTO_ENDPOINT=https://<tenant>.logto.app
# VITE_LOGTO_APP_ID=<app-id>
# VITE_LOGTO_API_RESOURCE=https://api.tavrida-lot.localhost

# Image proxy — see ../../.env.example (VITE_IMAGE_PROXY_*)
