# Local-only Novu CE secrets (NOT for production).
# NOVU_SECRET_KEY здесь ≠ ApiKey для triggers — ключ берётся из Dashboard (см. docs/04-deployment/novu-local.md).
# Dashboard: http://localhost:4000 · API: http://localhost:3020

HOST_NAME=http://localhost
NODE_ENV=local

JWT_SECRET=tavrida-local-novu-jwt-not-for-production-use
# Exactly 32 characters:
STORE_ENCRYPTION_KEY=tavrida-local-novu-enc-32chars!!
NOVU_SECRET_KEY=tavrida-local-novu-secret-key-not-prod
SUBSCRIBER_WIDGET_JWT_EXPIRATION_TIME=15d

MONGO_INITDB_ROOT_USERNAME=novu
MONGO_INITDB_ROOT_PASSWORD=novu
MONGO_URL=mongodb://novu:novu@novu-mongo:27017/novu-db?authSource=admin
MONGO_AUTO_CREATE_INDEXES=true
MONGO_MIN_POOL_SIZE=2
MONGO_MAX_POOL_SIZE=10

REDIS_HOST=novu-redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CACHE_SERVICE_HOST=novu-redis
REDIS_CACHE_SERVICE_PORT=6379
REDIS_SKIP_VERSION_CHECK=false

# Host-published API/WS (BFF uses :3000; Novu API → :3020, WS → :3022)
API_PORT=3000
WS_PORT=3002
WORKER_PORT=3004
API_ROOT_URL=http://localhost:3020
FRONT_BASE_URL=http://localhost:4000
VITE_API_HOSTNAME=http://localhost:3020
VITE_WEBSOCKET_HOSTNAME=http://localhost:3022

S3_LOCAL_STACK=http://localhost:4566
S3_BUCKET_NAME=novu-local
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

IS_API_IDEMPOTENCY_ENABLED=false
IS_API_RATE_LIMITING_ENABLED=false
IS_NEW_MESSAGES_API_RESPONSE_ENABLED=true
IS_V2_ENABLED=true
IS_SELF_HOSTED=true
IS_EMAIL_INLINE_CSS_DISABLED=false
IS_USE_MERGED_DIGEST_ID_ENABLED=false

SENTRY_DSN=
NEW_RELIC_ENABLED=false
NEW_RELIC_APP_NAME=novu-local
NEW_RELIC_LICENSE_KEY=

BROADCAST_QUEUE_CHUNK_SIZE=100
MULTICAST_QUEUE_CHUNK_SIZE=100
