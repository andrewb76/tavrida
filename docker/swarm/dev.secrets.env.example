# Dev Swarm — секреты (NEVER commit the real file)
#
#   cp docker/swarm/dev.secrets.env.example docker/swarm/dev.secrets.env
#   # fill values, then from laptop:
#   DOCKER_CONTEXT=dev-swarm ./docker/swarm/sync-secrets-dev.sh
#
# Деплой stack тоже с ноутбука (секреты не кладём на VPS):
#   DOCKER_CONTEXT=dev-swarm ./docker/swarm/deploy-dev.sh
#
# Имена Swarm secrets: tavrida_dev_<key_lowercase>
# (см. sync-secrets-dev.sh и secrets-manifest.dev)

POSTGRES_PASSWORD=postgres
RABBITMQ_PASSWORD=guest
MINIO_ROOT_PASSWORD=minioadmin
LOGTO_M2M_APP_SECRET=
# Generate once per environment, e.g. `openssl rand -hex 32`.
INTERNAL_SERVICE_TOKEN=
