# Dev Swarm — публичный конфиг (можно держать на VPS; без паролей)
# Секреты: dev.secrets.env.example → dev.secrets.env (только на ноутбуке)
#
#   cp docker/swarm/dev.env.example docker/swarm/dev.env
#   cp docker/swarm/dev.secrets.env.example docker/swarm/dev.secrets.env
#
# Деплой с ноутбука через named context (рекомендуется):
#   docker context create dev-swarm --docker "host=ssh://user@193.142.148.175"
#   DOCKER_CONTEXT=dev-swarm ./docker/swarm/sync-secrets-dev.sh
#   DOCKER_CONTEXT=dev-swarm ./docker/swarm/deploy-dev.sh

# --- Domain / edge ---
# Public host zone (app/api/s3/… subdomains). See docs/04-deployment/dev-evatorg.md
DEV_DOMAIN=evatorg.su
ACME_EMAIL=devops@example.com
TRAEFIK_SWARM_NETWORK=tavrida-dev_tavrida_net
# Absolute checkout on Swarm manager (bind-mounts for Traefik/Keto/Postgres init)
TAVRIDA_REPO_ROOT=/opt/tavrida

# --- GHCR (core services pull from registry) ---
GHCR_REGISTRY=ghcr.io
GHCR_OWNER=andrewb76
GIT_SHA=latest

# --- Postgres (user/db — пароль в dev.secrets.env + Swarm secret) ---
POSTGRES_USER=postgres
POSTGRES_DB=tavrida_lot

# --- RabbitMQ (пароль в dev.secrets.env) ---
RABBITMQ_USER=guest

# --- MinIO (пароль в dev.secrets.env) ---
MINIO_ROOT_USER=minioadmin

# --- Logto avatar storage (MinIO bucket logto-avatars) ---
# Internal URL for Logto container; public URL for browser-loaded avatars.
LOGTO_STORAGE_BUCKET=logto-avatars
LOGTO_STORAGE_INTERNAL_ENDPOINT=http://minio:9000
LOGTO_STORAGE_PUBLIC_URL=https://s3.evatorg.su/logto-avatars
# Swarm service name for optional restart after pnpm setup:logto-storage
LOGTO_SWARM_SERVICE=tavrida-dev_logto

# --- Logto OSS (self-hosted on Swarm: auth.<DEV_DOMAIN> + logto.<DEV_DOMAIN>) ---
# After first deploy: open https://logto.evatorg.su → create SPA + API resource + M2M.
# Management API resource for OSS is always https://default.logto.app/api
LOGTO_ENDPOINT=https://auth.evatorg.su
LOGTO_JWKS_URL=https://auth.evatorg.su/oidc/jwks
LOGTO_AUDIENCE=https://api.evatorg.su
LOGTO_M2M_APP_ID=
LOGTO_M2M_RESOURCE=https://default.logto.app/api
FRONTEND_ORIGIN=https://app.evatorg.su

# Frontend build-time (build-images.sh) — same endpoint as LOGTO_ENDPOINT
VITE_LOGTO_ENDPOINT=https://auth.evatorg.su
VITE_LOGTO_APP_ID=
VITE_LOGTO_API_RESOURCE=https://api.evatorg.su

# --- Keto ---
KETO_READ_URL=http://keto:4466
KETO_WRITE_URL=http://keto:4467
