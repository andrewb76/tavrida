{
  "name": "@tavrida/bff",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "BFF_PORT=3000 nodemon --exec ts-node src/main.ts",
    "build": "pnpm --filter @tavrida/object-storage run build && pnpm --filter @tavrida/monetization-engine run build && tsc --build",
    "lint": "eslint src",
    "pretest": "pnpm run build",
    "test": "node --test dist/**/*.test.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.758.0",
    "@aws-sdk/s3-request-presigner": "^3.758.0",
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/typeorm": "^11.0.3",
    "@tavrida/monetization-engine": "workspace:*",
    "@tavrida/object-storage": "workspace:*",
    "amqplib": "^0.10.9",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "jose": "^6.0.11",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "uuid": "^14.0.1",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@tavrida/tsconfig": "workspace:*",
    "@types/amqplib": "^0.10.8",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.11",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
